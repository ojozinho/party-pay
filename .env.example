# Party Pay environment example
# Copy this file to .env and fill locally.
# Never commit real secrets.

EXPO_PUBLIC_APP_ENV=prototype

# Supabase optional prototype variables
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Never expose service role in mobile code.
# SUPABASE_SERVICE_ROLE_KEY must be backend-only and should not be used in this prototype app.
